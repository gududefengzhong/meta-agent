# Copy to `.env` (gitignored) and fill in real values for local dev.
# Production deployments inject these via the platform secret manager;
# the application never reads `.env` files directly — values reach the
# process strictly through the environment.

# --- Persistence ---------------------------------------------------
# Async driver URL consumed by alembic + asyncpg pool.
META_AGENT_DB_URL=postgresql+asyncpg://meta_agent:dev-only@localhost:5432/meta_agent

# --- Queue ---------------------------------------------------------
META_AGENT_REDIS_URL=redis://localhost:6379/0

# --- LLM provider --------------------------------------------------
# OpenRouter gateway: https://openrouter.ai/keys
# DO NOT commit real keys. Rotate any key that ever touched a chat
# transcript, screenshot, log file, or shared shell history.
OPENROUTER_API_KEY=sk-or-v1-<your-key-here>
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Default model id used by the OpenRouter adapter when callers do not
# pin one explicitly. Use OpenRouter's slug format (provider/name).
OPENROUTER_DEFAULT_MODEL=deepseek/deepseek-chat

# --- Local auth ----------------------------------------------------
# For local dev, keep auth on the env-backed validator unless you have
# explicitly provisioned hashed keys in the Postgres api_keys table.
META_AGENT_AUTH_BACKEND=env
META_AGENT_API_KEYS=dev-token:default-tenant:default-user

# --- Auto PR / GitHub ----------------------------------------------
# Worker default is META_AGENT_GIT_PROVIDER=fake, which means bug_fix can
# still succeed locally but push/auto_pr will not fire. Set the provider
# to github and provide one token to enable both:
#   1. git push from bug_fix_v2
#   2. PR creation/reuse from builtin.auto_pr
META_AGENT_GIT_PROVIDER=fake
META_AGENT_GITHUB_TOKEN=
# Optional GitHub Enterprise / custom tuning:
# META_AGENT_GITHUB_BASE_URL=https://api.github.com
# META_AGENT_GITHUB_USER_AGENT=meta-agent/0.0
